{
    "compilerOptions": {
        "target": "ES2022",
        "useDefineForClassFields": true,
        "module": "ES2022",
        "lib": ["ES2024", "DOM"],
        "moduleResolution": "bundler",
        // bongle self-refs (`bongle/internal`, …) resolve to SOURCE here, not the
        // built dist .d.ts, so lib typechecks against ONE instance of each type —
        // else a type reached both relatively (src) and via bongle/* (dist d.ts)
        // reads as two identities (TS2717). External consumers have no `source`
        // condition, so they get the shipped d.ts.
        "customConditions": ["source"],
        "jsx": "react-jsx",
        "strict": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "noEmit": true,
        "declaration": true,
        "emitDeclarationOnly": true,
        "declarationDir": "./dist",
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "skipLibCheck": true,
        "rootDir": "./",
        "allowSyntheticDefaultImports": true
    },
    "include": ["./src", "./tst", "./editor", "./build", "./cli"],
    "exclude": ["./dist", "**/*.bench.ts", "**/*-bench.ts"]
}
