{
    "name": "bongle",
    "version": "0.0.0-alpha.1",
    "license": "MIT",
    "type": "module",
    "sideEffects": [
        "src/index.ts",
        "src/engine-client.ts",
        "src/engine-server.ts",
        "src/engine-editor.ts",
        "src/internal.ts",
        "src/builtins/**",
        "src/core/physics/crashcat.ts"
    ],
    "bin": {
        "bongle": "./kit/bin.mjs"
    },
    "exports": {
        ".": {
            "import": "./src/index.ts",
            "default": "./src/index.ts"
        },
        "./engine-client": {
            "import": "./src/engine-client.ts",
            "default": "./src/engine-client.ts"
        },
        "./engine-server": {
            "import": "./src/engine-server.ts",
            "default": "./src/engine-server.ts"
        },
        "./engine-server-node": {
            "import": "./src/engine-server-node.ts",
            "default": "./src/engine-server-node.ts"
        },
        "./engine-editor": {
            "import": "./src/engine-editor.ts",
            "default": "./src/engine-editor.ts"
        },
        "./engine-asset-pipeline": {
            "import": "./src/asset-pipeline/index.ts",
            "default": "./src/asset-pipeline/index.ts"
        },
        "./editor/fs": {
            "import": "./editor/fs.ts",
            "default": "./editor/fs.ts"
        },
        "./editor/fs-opfs": {
            "import": "./editor/fs-opfs.ts",
            "default": "./editor/fs-opfs.ts"
        },
        "./internal": {
            "import": "./src/internal.ts",
            "default": "./src/internal.ts"
        },
        "./interface": {
            "import": "./interface/index.ts",
            "default": "./interface/index.ts"
        },
        "./kit": {
            "import": "./kit/index.ts",
            "default": "./kit/index.ts"
        },
        "./kit/runtime/*": {
            "import": "./kit/runtime/*.ts",
            "default": "./kit/runtime/*.ts"
        },
        "./avatar/rig": {
            "import": "./src/core/avatar/rig.ts",
            "default": "./src/core/avatar/rig.ts"
        },
        "./starter": {
            "import": "./src/starter/index.ts",
            "default": "./src/starter/index.ts"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "src",
        "kit",
        "interface",
        "avatars",
        "assets",
        "templates",
        "LICENSE",
        "README.md"
    ],
    "scripts": {
        "docs": "tsgo -p docs/template/tsconfig.json && node docs/template/build.js",
        "build": "rm -rf dist vendor && vite build --config vite.lib.config.ts && node scripts/gather-lib-runtime.mjs && node scripts/pack-vfs.mjs && tsgo -p tsconfig.build.json && node scripts/gather-lib-types.mjs",
        "test": "vitest run",
        "bench": "vitest bench --run",
        "typecheck": "tsgo -p tsconfig.json",
        "lint": "biome check src tst",
        "lint:fix": "biome check --write src tst",
        "blockbench:build": "bongle-blockbench/build.sh",
        "blockbench:plugin": "bongle-blockbench/build-plugin.sh"
    },
    "dependencies": {
        "@base-ui/react": "^1.5.0",
        "@breezystack/lamejs": "^1.2.7",
        "@dnd-kit/abstract": "^0.3.2",
        "@dnd-kit/dom": "^0.3.2",
        "@dnd-kit/helpers": "^0.3.2",
        "@dnd-kit/react": "^0.3.2",
        "@dnd-kit/state": "^0.3.2",
        "@gltf-transform/core": "^4.3.0",
        "@gltf-transform/functions": "^4.3.0",
        "@rolldown/browser": "^1.1.5",
        "@tailwindcss/vite": "^4.2.2",
        "@tanstack/react-virtual": "^3.13.24",
        "archiver": "^7.0.1",
        "canvas": "^3.2.3",
        "crashcat": "github:isaac-mason/crashcat#dev",
        "fflate": "^0.8.2",
        "gpucat": "github:isaac-mason/gpucat#8dae93190e99c91c810fd772a3239279b18c5153",
        "lucide-react": "^1.7.0",
        "magic-string": "^0.30.21",
        "mathcat": "github:isaac-mason/mathcat#dev",
        "meshoptimizer": "^0.25.0",
        "monaco-editor": "^0.55.1",
        "packcat": "github:isaac-mason/packcat#dev",
        "react": "^19.2.4",
        "react-colorful": "^5.7.0",
        "react-dom": "^19.2.4",
        "sharp": "^0.34.5",
        "skia-canvas": "^3.0.0",
        "vite": "^8.1.0",
        "ws": "^8.18.0",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.13",
        "@tailwindcss/vite": "^4.2.2",
        "@types/archiver": "^6.0.3",
        "@types/estree": "^1.0.8",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/ws": "^8.5.13",
        "@typescript/native-preview": "7.0.0-dev.20260421.2",
        "@webgpu/types": "^0.1.71",
        "dts-bundle-generator": "^9.5.1",
        "happy-dom": "^20.8.9",
        "rolldown-plugin-dts": "^0.27.1",
        "tailwindcss": "^4.2.2",
        "tsdown": "^0.22.3",
        "tslib": "^2.8.1",
        "typescript": "^5.9.2",
        "vitest": "^4.1.0"
    },
    "packageManager": "pnpm@10.30.3",
    "onlyBuiltDependencies": [
        "canvas",
        "esbuild",
        "sharp",
        "skia-canvas"
    ]
}
